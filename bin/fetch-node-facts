#!/usr/bin/env ruby
# frozen_string_literal: true

# Fetch Puppet facts from a remote host via SSH and save them locally
# for offline catalog-diff runs.
#
# Usage: fetch-node-facts <certname>
#
#   certname — the Puppet certname (used as the fact file name and SSH hostname)
#

require 'fileutils'
require 'json'
require 'yaml'
require 'open3'

def abort_with_message(msg)
  $stderr.puts "Error: #{msg}"
  exit 1
end

certname = ARGV[0] or abort "Usage: #{$0} <certname>"

# Try to resolve the actual SSH host using assh if available
ssh_host = certname
if system('which assh >/dev/null 2>&1')
  customer_id = certname.split('.').last
  if system("assh config search #{certname} >/dev/null 2>&1")
    ssh_host = certname
  elsif customer_id != certname && system("assh config search #{customer_id} >/dev/null 2>&1")
    ssh_host = customer_id
  end
end

# Build SSH command
# Use a timeout and ensure we use the correct puppet binary path
cmd = "ssh -o ConnectTimeout=10 #{ssh_host} 'sudo /opt/puppetlabs/bin/puppet facts show --render-as json'"
$stderr.puts "Running: #{cmd}"

stdout, stderr, status = Open3.capture3(cmd)

unless status.success?
  $stderr.puts "SSH/facter failed (exit #{status.exitstatus})"
  $stderr.puts "Stderr: #{stderr}" unless stderr.empty?
  $stderr.puts "Make sure you can SSH to '#{ssh_host}' and have sudo privileges."
  exit status.exitstatus
end

begin
  values = JSON.parse(stdout)
rescue JSON::ParserError => e
  abort_with_message "Failed to parse puppet facts output as JSON: #{e.message}\nOutput was: #{stdout}"
end

doc = { 'name' => certname, 'values' => values }

out_dir  = File.expand_path('../e2e/facts', __dir__)
out_file = File.join(out_dir, "#{certname}.yaml")

begin
  FileUtils.mkdir_p(out_dir)
  File.write(out_file, doc.to_yaml)
  $stderr.puts "Wrote #{out_file}"
rescue StandardError => e
  abort_with_message "Failed to write fact file: #{e.message}"
end
